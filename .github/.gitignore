# This will create or overwrite .gitignore with safe defaults
@"
# Node
node_modules/

# Build output
dist/
/.vite/

# Local env files and secrets
.env
.env.*
env.local.js
env.*.local.js
env.production.js

# Editor folders
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
"@ | Out-File -Encoding utf8 .gitignore